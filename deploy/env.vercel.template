# Шаблон для Vercel: Settings → Environment Variables → Production (и Preview при желании).
# Скопируй файл как deploy/env.vercel.local (в .gitignore), подставь значения, потом внеси вручную в панель
# или используй: vercel env pull  (после vercel link) — см. deploy/VERCEL.md
#
# WEBHOOK_URL в Vercel НЕ задаётся — он только в локальном .env для скрипта set_webhook.py

BOT_TOKEN=
WEBHOOK_SECRET=
PERSISTENCE_PATH=/tmp/ptb.pkl
LEADS_FILE=/tmp/leads.jsonl

# Необязательно
BRAND_TITLE=Тест английского · Grammar Check
BRAND_SUBTITLE=Grammar & Usage (B2) · определение уровня и темы для повторения
LOG_LEVEL=INFO

# Обычно не нужно на Vercel (только если регион не достучится до api.telegram.org)
# TELEGRAM_PROXY=
