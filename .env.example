# Скопируй как `.env` в корень проекта и заполни. Файл `.env` в git не коммитить.
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Vercel (Production): см. готовый список ключей в deploy/env.vercel.template │
# │ Там же: что обязательно, что опционально. WEBHOOK_URL в Vercel не добавлять.  │
# └─────────────────────────────────────────────────────────────────────────────┘

# --- Обязательно (локально и на Vercel) ---
BOT_TOKEN=

# --- Только локально: регистрация webhook (после деплоя подставь свой URL) ---
# WEBHOOK_URL=https://твой-проект.vercel.app/api/webhook
# WEBHOOK_SECRET=тот_же_секрет_что_в_панели_Vercel

# --- На Vercel обязательно задать в панели (для стабильности сессии и лидов) ---
# PERSISTENCE_PATH=/tmp/ptb.pkl
# LEADS_FILE=/tmp/leads.jsonl

# --- Опционально ---
# BRAND_TITLE=Тест английского · Grammar Check
# BRAND_SUBTITLE=Grammar & Usage (B2) · определение уровня и темы для повторения
# LOG_LEVEL=INFO
# LEADS_FILE=/var/lib/english-bot/leads.jsonl
# TELEGRAM_PROXY=http://127.0.0.1:7890
# Для socks5: pip install "python-telegram-bot[socks]"
# SKIP_TELEGRAM_CHECK=1
